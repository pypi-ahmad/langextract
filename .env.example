# Copy this file to .env for local development. Fill only the values you use.
# Never commit populated secrets.

# TrafficMind runtime profile and local safety defaults.
TRAFFICMIND_PROFILE=local
# TRAFFICMIND_STALE_AFTER_SECONDS=60
# TRAFFICMIND_HISTORY_SIZE=100
# TRAFFICMIND_LOG_LEVEL=DEBUG
# TRAFFICMIND_POLLING_URL=http://127.0.0.1:8080/api/states
# TRAFFICMIND_POLLING_TIMEOUT=10
# TRAFFICMIND_WEBHOOK_MAX_BUFFER=10000

# Optional LangExtract provider credentials.
# LANGEXTRACT_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# GLM_OCR_API_KEY=